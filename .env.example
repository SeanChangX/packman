# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://packman:packman@localhost:5432/packman

# ─── MinIO ──────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=packman
MINIO_SECRET_KEY=packman_secret_change_me
MINIO_BUCKET=packman-items
MINIO_USE_SSL=false

# ─── Slack OAuth ─────────────────────────────────────────────
# Create app at https://api.slack.com/apps
# Scopes needed: identity.basic, identity.email, identity.avatar
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_WORKSPACE_ID=        # team ID from https://app.slack.com/client/TXXXXXXXX/
SLACK_REDIRECT_URI=http://YOUR_HOMELAB_IP:8080/auth/slack/callback

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── App URLs (used for QR code link generation) ─────────────
APP_URL=http://YOUR_HOMELAB_IP:3000
ADMIN_URL=http://YOUR_HOMELAB_IP:3001
API_URL=http://YOUR_HOMELAB_IP:8080

# ─── Admin Panel Basic Auth ──────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=change_me_strong_password
ADMIN_API_SECRET=change_me_long_random_secret

# ─── API ────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
