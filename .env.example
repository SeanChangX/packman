# ─── Postgres ───────────────────────────────────────────────
# Used by both the postgres container and the API. Change the password before
# exposing the host to anyone you don't fully trust on the same network.
POSTGRES_USER=packman
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=packman

# Only used by host-side tools (psql, prisma studio etc.). The API container
# reads its DATABASE_URL from docker-compose.yml using the postgres service name.
DATABASE_URL=postgresql://packman:change-me-postgres-password@localhost:5432/packman

# ─── MinIO ──────────────────────────────────────────────────
# MUST change MINIO_SECRET_KEY before deployment. Generate one with:
#   openssl rand -hex 32
MINIO_ACCESS_KEY=packman
MINIO_SECRET_KEY=change-me-minio-secret-key
MINIO_BUCKET=packman-items
MINIO_USE_SSL=false

# Host-side defaults (overridden inside docker-compose for the API container).
MINIO_ENDPOINT=localhost
MINIO_PORT=9000

# Optional: set this if MinIO is reachable from outside the docker network and
# you want photo URLs to point at the public hostname. Usually NOT needed —
# photos are served through the API at /api/items/:id/photo.
# MINIO_PUBLIC_URL=https://minio.your-domain.com

# ─── API ────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# Session lifetime for the JWT cookie. Accepts ms-style strings: 1h, 7d, 30d…
JWT_EXPIRES_IN=7d

# Set to "true" only if the browser reaches the API over HTTPS (e.g. through
# a reverse proxy with TLS). Default is off so plain HTTP LAN deployments work
# out of the box — Secure cookies are dropped by browsers over HTTP.
# COOKIE_SECURE=true

# ─── Notes ──────────────────────────────────────────────────
# The following are NOT environment variables — they are configured in the
# admin UI on first run and stored in the database:
#   - Slack Client ID / Secret / Workspace ID
#   - App URL / Admin URL / API URL
#   - Admin username + password
#   - Ollama endpoints / vision model / tagging prompt
#   - Brand name + logo
# JWT signing secret and cookie secret are auto-generated on first API
# startup and stored in the database too — no need to set them here.
