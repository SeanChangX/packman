generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  slackId     String   @unique
  name        String
  email       String?
  avatarUrl   String?
  role        Role     @default(MEMBER)
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  ownedItems   Item[]    @relation("ItemOwner")
  createdItems Item[]    @relation("ItemCreator")
  ownedBoxes   Box[]
  batteries    Battery[]
}

model Group {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("#6366f1")
  users     User[]
  items     Item[]
  createdAt DateTime @default(now())
}

model Event {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     Item[]
  boxes     Box[]
  batteries Battery[]
}

model Box {
  id             String         @id @default(uuid())
  label          String
  shippingMethod ShippingMethod
  ownerId        String?
  owner          User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  status         PackingStatus  @default(NOT_PACKED)
  notes          String?
  priority       Int?
  items          Item[]
  eventId        String
  event          Event          @relation(fields: [eventId], references: [id])
  createdAt      DateTime       @default(now())

  @@unique([label, eventId])
}

model Item {
  id             String          @id @default(uuid())
  name           String
  ownerId        String?
  owner          User?           @relation("ItemOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdById    String?
  createdBy      User?           @relation("ItemCreator", fields: [createdById], references: [id], onDelete: SetNull)
  shippingMethod String?
  groupId        String?
  group          Group?          @relation(fields: [groupId], references: [id], onDelete: SetNull)
  quantity       Int             @default(1)
  status         PackingStatus   @default(NOT_PACKED)
  notes          String?
  boxId          String?
  box            Box?            @relation(fields: [boxId], references: [id], onDelete: SetNull)
  useCategory    String?
  tags           String[]
  specialNotes   String?
  photoUrl       String?
  weightG        Int?
  aiTagStatus    AiTagStatus     @default(NONE)
  eventId        String
  event          Event           @relation(fields: [eventId], references: [id])
  createdAt      DateTime        @default(now())
  aiTagJobs       AiTagJob[]
}

model Battery {
  id          String   @id @default(uuid())
  batteryId   String   @unique
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  notes       String?
  batteryType String
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  createdAt   DateTime @default(now())
}

model SelectOption {
  id        String           @id @default(uuid())
  type      SelectOptionType
  value     String
  label     String
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())

  @@unique([type, value])
}

model BatteryRegulation {
  id        String   @id @default(uuid())
  title     String
  content   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model SystemSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OllamaEndpoint {
  id                  String    @id @default(uuid())
  baseUrl             String    @unique
  enabled             Boolean   @default(true)
  avgLatencyMs        Float?
  lastLatencyMs       Int?
  requestCount        Int       @default(0)
  failureCount        Int       @default(0)
  lastSuccessAt       DateTime?
  lastErrorAt         DateTime?
  lastError           String?
  healthAvgLatencyMs  Float?
  healthLastLatencyMs Int?
  healthCheckCount    Int       @default(0)
  healthFailureCount  Int       @default(0)
  healthLastSuccessAt DateTime?
  healthLastErrorAt   DateTime?
  healthLastError     String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model AiTagJob {
  id          String         @id @default(uuid())
  itemId      String
  item        Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  objectName  String
  status      AiTagJobStatus @default(QUEUED)
  attempts    Int            @default(0)
  maxAttempts Int            @default(3)
  nextRunAt   DateTime       @default(now())
  lockedAt    DateTime?
  lockedBy    String?
  lastError   String?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, nextRunAt])
  @@index([itemId, status])
}

enum Role {
  ADMIN
  MEMBER
}

enum ShippingMethod {
  CHECKED
  CARRY_ON
}

enum PackingStatus {
  NOT_PACKED
  PACKED
  SEALED
}

enum SelectOptionType {
  SHIPPING_METHOD
  USE_CATEGORY
  BATTERY_TYPE
}

enum AiTagStatus {
  NONE
  PENDING
  DONE
  FAILED
}

enum AiTagJobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
  CANCELLED
}
